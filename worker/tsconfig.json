{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "webworker"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@cloudflare/workers-types"],
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "src/**/*", 
    "../../pkg/**/*"
  ],
  "exclude": ["node_modules"]
}
